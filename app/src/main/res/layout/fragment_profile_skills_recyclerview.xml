<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <LinearLayout

        android:visibility="gone"
        android:id="@+id/fragmentProfileLinearLayout"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <Button

                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:textAlignment="center"
                android:lines="1"
                android:maxLines="1"
                android:visibility="gone"
                android:padding="0dp"
                android:id="@+id/fragmentProfileRecyclerViewTag1"
                app:cornerRadius="50dp"
                app:backgroundTint="@color/transaparent"
                app:backgroundTintMode="src_atop"
                android:textColor="@color/cinza_7"
                android:textSize="12sp"
                android:background="@drawable/material_button_30dp_border_background"
                android:layout_width="wrap_content"
                android:layout_height="32dp">
            </Button>
        </GridLayout>
        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <Button
                android:textAlignment="center"
                android:lines="1"
                android:maxLines="1"
                android:visibility="gone"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:id="@+id/fragmentProfileRecyclerViewTag2"
                app:cornerRadius="50dp"
                app:backgroundTint="@color/transaparent"
                app:backgroundTintMode="src_atop"
                android:padding="0dp"
                android:textColor="@color/cinza_7"
                android:textSize="12sp"
                android:background="@drawable/material_button_30dp_border_background"
                android:layout_marginStart="12dp"
                android:layout_width="wrap_content"
                android:layout_height="32dp">
            </Button>
        </GridLayout>
        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <Button
                android:textAlignment="center"
                android:lines="1"
                android:maxLines="1"
                android:visibility="gone"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:id="@+id/fragmentProfileRecyclerViewTag3"
                app:cornerRadius="50dp"
                app:backgroundTint="@color/transaparent"
                app:backgroundTintMode="src_atop"
                android:padding="0dp"
                android:textColor="@color/cinza_7"
                android:textSize="12sp"
                android:background="@drawable/material_button_30dp_border_background"
                android:layout_marginStart="12dp"
                android:layout_width="wrap_content"
                android:layout_height="32dp">
            </Button>
        </GridLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>